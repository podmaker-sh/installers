# PodMaker Vault Bridge — environment file consumed by the systemd
# unit. Mode 0600, owner bridge:bridge. Do NOT commit a filled copy.

PODMAKER_BRIDGE_ID=REPLACE_BRIDGE_ID
PODMAKER_BRIDGE_TOKEN=REPLACE_BEARER_TOKEN
PODMAKER_CP_URL=https://app.podmaker.sh

# One of: openbao | hashicorp-vault | aws-sm | gcp-sm | azure-kv |
# doppler | infisical | 1password-connect
PODMAKER_UPSTREAM_TYPE=aws-sm

# Upstream-specific knobs follow. Examples below; delete the ones
# that don't apply.

# --- AWS Secrets Manager ----------------------------------------
PODMAKER_UPSTREAM_REGION=eu-west-1
# Leave these blank to pick up creds from the environment (e.g.
# `aws-vault exec PROFILE` or an EC2 instance profile).
# PODMAKER_UPSTREAM_ACCESS_KEY_ID=
# PODMAKER_UPSTREAM_SECRET_ACCESS_KEY=
# PODMAKER_UPSTREAM_SESSION_TOKEN=

# --- HashiCorp Vault / OpenBao ----------------------------------
# PODMAKER_UPSTREAM_ENDPOINT=http://10.0.0.5:8200
# PODMAKER_UPSTREAM_TOKEN=hvs.xxxxx
# PODMAKER_UPSTREAM_KV_MOUNT=secret
# PODMAKER_UPSTREAM_NAMESPACE=acme/prod

# --- Doppler ----------------------------------------------------
# PODMAKER_UPSTREAM_TOKEN=dp.st.xxxx
# PODMAKER_UPSTREAM_PROJECT=podmaker
# PODMAKER_UPSTREAM_CONFIG=prod

# --- Metrics ----------------------------------------------------
PODMAKER_BRIDGE_METRICS_ADDR=127.0.0.1:7768
